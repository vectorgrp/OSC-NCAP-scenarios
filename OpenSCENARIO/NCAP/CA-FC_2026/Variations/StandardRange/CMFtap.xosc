<?xml version='1.0' encoding='utf-8'?>
<OpenSCENARIO xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../Schema/OpenSCENARIO.xsd">
  <!--Copyright (c) 2025-2026, Vector Informatik GmbH-->
  <FileHeader revMajor="1" revMinor="3" date="2026-02-24T14:44:00" description="Standard Range Parameter Variation for CMFtap scenario from Euro NCAP Crash Avoidance Frontal Collisions 2026 Protocol" author="Vector Informatik GmbH">
    <License name="Mozilla Public License Version 2.0" resource="https://www.mozilla.org/en-US/MPL/2.0/" spdxId="MPL-2.0" />
    <Properties>
      <Property name="DYNA4.Version" value="10.0.0" />
    </Properties>
  </FileHeader>
  <ParameterValueDistribution>
    <ScenarioFile filepath="../../CCFtap.xosc" />
    <Deterministic>
      <DeterministicSingleParameterDistribution parameterName="Scenario_ID">
        <DistributionSet>
          <Element value="CMFtap" />
        </DistributionSet>
      </DeterministicSingleParameterDistribution>
      <DeterministicSingleParameterDistribution parameterName="Target_catalogName">
        <DistributionSet>
          <Element value="Vehicles" />
        </DistributionSet>
      </DeterministicSingleParameterDistribution>
      <DeterministicSingleParameterDistribution parameterName="Target_catalogEntry">
        <DistributionSet>
          <Element value="NCAP_Motorcycle" />
        </DistributionSet>
      </DeterministicSingleParameterDistribution>
      <DeterministicSingleParameterDistribution parameterName="Target_length">
        <DistributionSet>
          <Element value="2.08" />
        </DistributionSet>
      </DeterministicSingleParameterDistribution>
      <DeterministicSingleParameterDistribution parameterName="Target_width">
        <DistributionSet>
          <Element value="0" />
        </DistributionSet>
        <!--setting width to 0 as center of motorcycle is targeted and not corner of its bounding box-->
      </DeterministicSingleParameterDistribution>
      <DeterministicSingleParameterDistribution parameterName="Target_BBcenter_x">
        <DistributionSet>
          <Element value="0.673" />
        </DistributionSet>
      </DeterministicSingleParameterDistribution>
      <DeterministicSingleParameterDistribution parameterName="Target_final_speed_kph">
        <DistributionSet>
          <Element value="30" />
          <Element value="45" />
          <Element value="60" />
        </DistributionSet>
      </DeterministicSingleParameterDistribution>
      <DeterministicMultiParameterDistribution>
        <ValueSetDistribution>
          <ParameterValueSet>
            <ParameterAssignment value="10" parameterRef="Ego_speed_kph" />
            <ParameterAssignment value="1500" parameterRef="Trajectory_R1" />
            <ParameterAssignment value="9" parameterRef="Trajectory_R2" />
            <ParameterAssignment value="20.62" parameterRef="Trajectory_alpha" />
            <ParameterAssignment value="48.76" parameterRef="Trajectory_beta" />
          </ParameterValueSet>
          <ParameterValueSet>
            <ParameterAssignment value="15" parameterRef="Ego_speed_kph" />
            <ParameterAssignment value="1500" parameterRef="Trajectory_R1" />
            <ParameterAssignment value="11.75" parameterRef="Trajectory_R2" />
            <ParameterAssignment value="20.93" parameterRef="Trajectory_alpha" />
            <ParameterAssignment value="48.14" parameterRef="Trajectory_beta" />
          </ParameterValueSet>
          <ParameterValueSet>
            <ParameterAssignment value="20" parameterRef="Ego_speed_kph" />
            <ParameterAssignment value="1500" parameterRef="Trajectory_R1" />
            <ParameterAssignment value="14.75" parameterRef="Trajectory_R2" />
            <ParameterAssignment value="21.79" parameterRef="Trajectory_alpha" />
            <ParameterAssignment value="46.42" parameterRef="Trajectory_beta" />
          </ParameterValueSet>
        </ValueSetDistribution>
      </DeterministicMultiParameterDistribution>
    </Deterministic>
  </ParameterValueDistribution>
</OpenSCENARIO>